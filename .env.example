 #Banco de dados MySQL 
 MYSQL_ROOT_PASSWORD=root 
 MYSQL_DATABASE=sgo_oficina 
 MYSQL_USER=sgo_user 
 MYSQL_PASSWORD=sgo_password 
 MYSQL_PORT=3306 
 
 #URL de conexão utilizada pela aplicação e pelo Drizzle ORM
 DATABASE_URL=mysql://sgo_user:sgo_password@localhost:3306/sgo_oficina 

 # Chave utilizada para assinatura/autenticação da sessão 
 AUTH_SECRET=altere_esta_chave_secreta 
 
 # Usuário administrador inicial criado pelo seed 
 ADMIN_EMAIL=admin@sgo.local 
 ADMIN_PASSWORD=admin123456 
 ADMIN_NAME=Administrador